# ─── PrecisionTraderPro — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your keys
# These can also be set in the Settings page inside the app

# OpenAI (Required for AI Analysis)
OPENAI_API_KEY=sk-...

# OANDA (Required for live trading & charts)
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=101-004-XXXXXXX-XXX

# Twelve Data (Required for live prices)
TWELVE_DATA_KEY=your-twelve-data-key

# Telegram (Optional — for trade alerts)
TELEGRAM_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=-100XXXXXXXXX

# Server
PORT=3001
NODE_ENV=development
