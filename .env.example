# ─── PrecisionTraderPro — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your keys
# These can also be set in the Settings page inside the app

# OpenAI (Required for AI Analysis)
OPENAI_API_KEY=sk-...

# Anthropic / Claude (Optional — reserved for future AI validation layer)
ANTHROPIC_API_KEY=sk-ant-...

# OANDA (Required for live trading & charts)
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=101-004-XXXXXXX-XXX

# Twelve Data (Required for live prices)
TWELVE_DATA_KEY=your-twelve-data-key

# Telegram (Optional — for trade alerts)
TELEGRAM_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=-100XXXXXXXXX

# MT5 via MetaApi (Optional — read-only mirror of an MT5 demo/live account)
# 1. Sign up at https://app.metaapi.cloud  2. Add your MT5 account (login/password/server)
# 3. Copy the account id here, and generate an API token.
METAAPI_TOKEN=your-metaapi-token
METAAPI_ACCOUNT_ID=your-metaapi-account-id
# Region the MetaApi account is provisioned in (shown in the dashboard): new-york, london, singapore...
METAAPI_REGION=new-york

# Server
PORT=3001
NODE_ENV=development
